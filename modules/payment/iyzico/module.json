      "options": {
        "https://sandbox-api.iyzipay.com": "Test (Sandbox)",
        "https://api.iyzipay.com": "Canlı"
      },
      "default": "https://sandbox-api.iyzipay.com"
    },
    "installment": {
      "label": "Taksit Seçeneği",
      "type": "checkbox",
      "default": "1"
    },
    "card_storage": {
      "label": "Kart Saklama",
      "type": "checkbox",
      "default": "1"
    }
  }
