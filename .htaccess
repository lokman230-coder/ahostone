# Ahost One root rewrite rules
# Required for SEO URLs like /urun/baslangic-sitebuilder-1, /domain, /client, /admin etc.

Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Keep install.php, existing files and existing folders directly accessible
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all friendly URLs to the MVC front controller
    RewriteRule ^ index.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "^(\.env|composer\.(json|lock)|package(-lock)?\.json|README|.*\.md|.*\.sql|.*\.log)$">
    Require all denied
</FilesMatch>
